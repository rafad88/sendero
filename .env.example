# Copy this to .env and fill in your credentials
# These are injected via --dart-define at build time (see .vscode/launch.json)

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional — Thunderforest Landscape tiles (free at thunderforest.com/maps/sign-up)
# Without this key the app falls back to OSM standard tiles.
THUNDERFOREST_API_KEY=
